# DEVORQ - Gitignore

# Worktrees isolados
.worktrees/

# Temporary files
*.tmp
*.temp
*.log

# OS files
.DS_Store
Thumbs.db

# IDE files
.idea/
.vscode/
*.swp
*.swo

# Test output
/tmp/
/coverage/

# Environment
.env
.env.local

# Node modules (if any tooling is added later)
node_modules/

# Build artifacts
/dist/
/build/

# Backup files
*.bak
*.backup

# DEVORQ - Arquivos de estado em runtime (nao versionados)
.devorq/state/session.json
.devorq/state/skills.json
.devorq/state/agents.json
.devorq/state/validations.json
.devorq/state/confidence.json
.devorq/state/unified.json
.devorq/state/kb_failures.log
.devorq/state/error-log.json
.devorq/state/activation_snapshot.json
.devorq/backups/
.devorq/analysis/
.devorq/state/sprints/
.devorq/state/tasklist/
.devorq/state/lessons-pending/
.devorq/state/lessons-learned/
.devorq/state/contracts/
.devorq/state/checkpoints/
.devorq/state/specs/
.devorq/state/session-audits/
.devorq/.cache/

# Serena (configuracao local)
.serena/

# AI Instructions gerado
AI_INSTRUCTIONS.md

# IDE e editores
.claude/
# Mas rastrear subdir commands para backup
!.claude/commands/
