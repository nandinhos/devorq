{
  "mcpServers": {
    "serena": {
      "command": "uvx",
      "args": [
        "serena",
        "--project=."
      ]
    },
    "basic-memory": {
      "command": "uvx",
      "args": [
        "basic-memory",
        "mcp"
      ]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    }
  }
}