# DEVORQ — Variáveis de ambiente
# Copie para .env e preencha os valores antes de rodar docker compose up

# Banco de dados PostgreSQL
DB_DATABASE=devorq
DB_USERNAME=devorq
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION

# pgAdmin
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=CHANGE_ME_IN_PRODUCTION

# Portas (opcionais — altere apenas se houver conflito)
APP_PORT=8900
FORWARD_DB_PORT=54320
PGADMIN_PORT=8950

# Docker
WWWUSER=1000
WWWGROUP=1000
