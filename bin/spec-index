#!/usr/bin/env bash
set -eEo pipefail

SPECS_DIR="docs/specs"
INDEX_FILE="$SPECS_DIR/_index.md"

extract_front_matter() {
    local file="$1"
    local field="$2"
    local value
    # Extrair apenas do bloco Front Matter real (entre os dois primeiros '---')
    value=$(awk -v field="${field}" '
        /^---$/ { n++; next }
        n == 1 && $0 ~ "^" field ":" { sub("^" field ":[ ]*", ""); print; exit }
        n >= 2 { exit }
    ' "$file" | xargs 2>/dev/null)
    echo "${value:-N/A}"
}

generate_index() {
    local ts=$(date "+%Y-%m-%d %H:%M:%S")
    
    echo "# Índice de Specs DEVORQ"
    echo ""
    echo "_Gerado automaticamente em ${ts}_"
    echo ""
    
    echo "## Resumo por Status"
    echo ""
    echo "| Status | Total |"
    echo "|--------|-------|"
    local status_enum=(draft planning approved in_progress implemented validated blocked archived)
    for s in "${status_enum[@]}"; do
        local count
        count=$({ grep -l "^status: ${s}$" "$SPECS_DIR"/*.md 2>/dev/null || true; } | wc -l | tr -d ' ')
        [[ "$count" -gt 0 ]] && echo "| ${s} | ${count} |"
    done
    echo ""
    
    echo "## Resumo por Domínio"
    echo ""
    echo "| Domínio | Total |"
    echo "|---------|-------|"
    local domain_enum=(arquitetura importacao ui_ux refactor seguranca operacao)
    for d in "${domain_enum[@]}"; do
        local count
        count=$({ grep -l "^domain: ${d}$" "$SPECS_DIR"/*.md 2>/dev/null || true; } | wc -l | tr -d ' ')
        [[ "$count" -gt 0 ]] && echo "| ${d} | ${count} |"
    done
    echo ""
    
    echo "## Todas as Specs"
    echo ""
    echo "| ID | Título | Domínio | Status | Prioridade | Atualizado |"
    echo "|----|--------|---------|--------|------------|------------|"
    
    # Loop dinâmico sobre os arquivos de spec (exceto o próprio índice)
    for spec_file in "$SPECS_DIR"/*.md; do
        [[ "$spec_file" == *"/_index.md" ]] && continue
        
        local id=$(extract_front_matter "$spec_file" "id")
        local title=$(extract_front_matter "$spec_file" "title")
        local domain=$(extract_front_matter "$spec_file" "domain")
        local status=$(extract_front_matter "$spec_file" "status")
        local priority=$(extract_front_matter "$spec_file" "priority")
        local updated=$(extract_front_matter "$spec_file" "updated_at")
        
        # Só inclui se tiver ID (evita arquivos sem front matter)
        if [[ "$id" != "N/A" ]]; then
            echo "| $id | $title | $domain | $status | $priority | $updated |"
        fi
    done | sort # Ordena por ID
    
    echo ""
    echo "## Alertas"
    echo ""
    echo "- Nenhum alerta crítico"
}

generate_index > "$INDEX_FILE"
echo "Índice gerado dinamicamente: $INDEX_FILE"
