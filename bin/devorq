#!/bin/bash
# DEVORQ - CLI Principal
# Orquestrador de desenvolvimento orientado a skills

set -eEo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"

if [ -d "$HOME/.devorq" ]; then
    DEVORQ_ROOT="$HOME/.devorq"
else
    DEVORQ_ROOT="$SCRIPT_DIR"
fi

DEVORQ_DIR="$DEVORQ_ROOT/.devorq"

if [ ! -d "$DEVORQ_ROOT/lib" ]; then
    echo "ERRO: Diretório de libs não encontrado: $DEVORQ_ROOT/lib" >&2
    exit 1
fi

if [ ! -d "$DEVORQ_DIR" ]; then
    mkdir -p "$DEVORQ_DIR"
fi

# Verificar dependência obrigatória: jq
if ! command -v jq >/dev/null 2>&1; then
    echo "ERRO: 'jq' é uma dependência obrigatória do DEVORQ." >&2
    echo "Instale com: apt install jq  /  brew install jq  /  dnf install jq" >&2
    exit 1
fi

# Verificar versão (avisa se desatualizado)
check_devorq_version() {
    if [ ! -f "$HOME/.devorq/VERSION" ]; then
        return 0
    fi

    local global_version
    global_version=$(cat "$HOME/.devorq/VERSION")

    if [ -f ".devorq/version" ]; then
        local local_version
        local_version=$(cat ".devorq/version")
        if [ "$local_version" != "$global_version" ]; then
            echo -e "${YELLOW}[WARN]${NC} Nova versão disponível: $global_version (você tem: $local_version)"
            echo "Execute: devorq update"
            echo ""
        fi
    fi
}

# Cores
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

log() { echo -e "${CYAN}[DEVORQ]${NC} $1"; }
log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}✓${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

validate_spec_id() {
    local spec_id="$1"
    if [[ "$spec_id" =~ ^SPEC-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{4}.*$ ]]; then
        return 0
    fi
    return 2
}

# Carregar módulos
source "$DEVORQ_ROOT/lib/core.sh"
source "$DEVORQ_ROOT/lib/detect.sh"
source "$DEVORQ_ROOT/lib/lessons.sh"
source "$DEVORQ_ROOT/lib/handoff.sh"

# Verificar versão (só em projetos com .devorq)
if [ -d ".devorq" ] && [ -f ".devorq/version" ]; then
    check_devorq_version
fi

# =====================================================
# COMANDOS
# =====================================================

cmd_init() {
    log "🚀 Inicializando DEVORQ..."
    
    # Criar estrutura
    mkdir -p "$DEVORQ_DIR/state"/{checkpoints,session-audits,spec-exports,lessons-learned,brainstorms,contracts,specs}
    mkdir -p "$DEVORQ_DIR/rules"
    mkdir -p "$DEVORQ_DIR/docs"
    
    # Detectar contexto
    local stack
    stack=$(detect_stack "$DEVORQ_ROOT")
    local project_type
    project_type=$(detect_project_type "$DEVORQ_ROOT")
    local llm
    llm=$(detect_llm)
    local runtime
    runtime=$(detect_runtime)
    local db
    db=$(detect_database)
    
    log_info "Stack: $stack"
    log_info "Tipo: $project_type"
    log_info "LLM: $llm"
    log_info "Runtime: $runtime"
    log_info "Banco: $db"

    # Detectar Context-Mode (Modo Monstro)
    local ctx_status
    ctx_status=$(detect_context_mode "$DEVORQ_ROOT")
    if [[ "$ctx_status" == not_installed ]]; then
        log_warn "Context-Mode: nao instalado (Modo Monstro desativado)"
    elif [[ "$ctx_status" == no_session ]]; then
        log_info "Context-Mode: sem sessao para este projeto"
        log_info "Execute: devorq context-mode init"
    elif [[ "$ctx_status" == no_sessions ]]; then
        log_warn "Context-Mode: sem sessoes ativas"
        log_info "Execute: devorq context-mode init"
    else
        local ctx_hash=$(echo "$ctx_status" | cut -d: -f2)
        local ctx_size=$(echo "$ctx_status" | cut -d: -f3)
        log "🐉 Context-Mode: ✅ ATIVO (${ctx_hash}.db, ${ctx_size}KB)"
    fi

    # Detectar PRD
    local prd
    prd=$(check_prd_exists "$DEVORQ_ROOT")
    if [ -n "$prd" ]; then
        log_info "PRD: $prd"
    else
        log_info "PRD: não encontrado"
    fi
    
    # Detectar legado
    if is_legacy "$DEVORQ_ROOT"; then
        log_warn "Sistema LEGADO detectado"
    fi
    
    # Salvar state
    cat > "$DEVORQ_DIR/state/session.json" << EOF
{
  "stack": "$stack",
  "project_type": "$project_type",
  "llm": "$llm",
  "runtime": "$runtime",
  "database": "$db",
  "prd": "$prd",
  "initialized_at": "$(date -Iseconds)",
  "version": "1.0.0-dev"
}
EOF
    
    # Criar regras do projeto
    establish_project_rules "$project_type" "$stack"
    
    log_success "DEVORQ inicializado!"
}

establish_project_rules() {
    local project_type="$1"
    local stack="$2"
    
    case "$project_type" in
        "greenfield")
            cat > "$DEVORQ_DIR/rules/project.md" << EOF
# Regras do Projeto - Greenfield

## Contexto
- Tipo: Sistema novo
- Stack: $stack
- Regra: Arquitetura primeiro, código depois

## Regras de Ouro
1. TDD Obrigatório
2. PRD como fonte de verdade
3. Code Review antes de merge

## Padrões
- Estrutura: MVC padrão
- Testes: Feature tests
- Linter: Pint
EOF
            ;;
        "brownfield")
            cat > "$DEVORQ_DIR/rules/project.md" << EOF
# Regras do Projeto - Brownfield

## Contexto
- Tipo: Projeto em andamento
- Stack: $stack
- Regra: "First, do no harm"

## Regras de Ouro
1. Consistência com padrões existentes
2. TDD para novas funcionalidades
3. Minimalismo
4. Documentar com /learned-lesson
EOF
            ;;
    esac
}

cmd_flow() {
    shift
    local intent="$1"
    
    if [ -z "$intent" ]; then
        log_error "Intent necessário. Uso: devorq flow 'minha task'"
        exit 1
    fi
    
    # Executar fluxo completo
    bash "$DEVORQ_ROOT/lib/orchestration/flow.sh" flow "$intent"
}

cmd_agent() {
    log "=== DEVORQ AGENT MODE ==="
    echo ""
    
    # Mostrar contexto atual
    local stack
    stack=$(detect_stack "$DEVORQ_ROOT")
    local project_type
    project_type=$(detect_project_type "$DEVORQ_ROOT")
    local llm
    llm=$(detect_llm)
    local runtime
    runtime=$(detect_runtime)
    
    cat << EOF
Stack:     $stack
Tipo:      $project_type
LLM:       $llm
Runtime:   $runtime
Versão:    $(cat "$DEVORQ_ROOT/VERSION")

## Fluxo Completo:
1. /env-context     → Detectar contexto automaticamente
2. /scope-guard     → Contrato de escopo (OBRIGATÓRIO)
3. /pre-flight      → Validar tipos/enums
4. /schema-validate → Validar banco
5. tdd              → RED → GREEN → REFACTOR
6. /quality-gate    → Checklist (OBRIGATÓRIO)
7. /session-audit   → Métricas (OBRIGATÓRIO)
8. checkpoint       → Para continuidade

## Para iniciar uma task:
  devorq flow "implementar feature X"
EOF
}

cmd_context() {
    export_context
}

cmd_checkpoint() {
    local timestamp
    timestamp=$(date +%Y%m%d_%H%M%S)
    local checkpoint_dir="$DEVORQ_DIR/state/checkpoints"
    
    mkdir -p "$checkpoint_dir"
    
    local git_status=""
    if git rev-parse --git-dir > /dev/null 2>&1; then
        git_status=$(git status --short 2>/dev/null | head -10)
    fi
    
    cat > "$checkpoint_dir/cp_${timestamp}.md" << EOF
# Checkpoint - $timestamp

## Git Status
\`\`\`
$git_status
\`\`\`

## Contexto
- Stack: $(detect_stack "$DEVORQ_ROOT")
- Tipo: $(detect_project_type "$DEVORQ_ROOT")
- LLM: $(detect_llm)
EOF
    
    log_success "Checkpoint: cp_${timestamp}.md"
}

cmd_info() {
    local ctx_status
    ctx_status=$(detect_context_mode "$DEVORQ_ROOT")

    local ctx_line=""
    case "$ctx_status" in
        active:*)
            local ctx_hash=$(echo "$ctx_status" | cut -d: -f2)
            local ctx_size=$(echo "$ctx_status" | cut -d: -f3)
            ctx_line="🐉 Context: ✅ ATIVO (${ctx_hash}.db, ${ctx_size}KB)"
            ;;
        no_session)
            ctx_line="🐉 Context: ⚠️ sem sessao (execute: devorq context-mode init)"
            ;;
        no_sessions)
            ctx_line="🐉 Context: ⚠️ sem sessoes ativas"
            ;;
        not_installed)
            ctx_line="🐉 Context: ❌ nao instalado"
            ;;
    esac

    cat << EOF
=== DEVORQ CONTEXT ===
Stack:     $(detect_stack "$DEVORQ_ROOT")
Tipo:      $(detect_project_type "$DEVORQ_ROOT")
LLM:       $(detect_llm)
Runtime:   $(detect_runtime)
Banco:     $(detect_database)
Versao:    $(cat "$DEVORQ_ROOT/VERSION")
${ctx_line}
EOF
}

cmd_skills() {
    local skills_dir="$DEVORQ_DIR/skills"

    if [ ! -d "$skills_dir" ]; then
        echo "Skills DEVORQ (0 skills):"
        return 0
    fi

    echo "Skills DEVORQ ($(ls -1 "$skills_dir/" 2>/dev/null | wc -l | tr -d ' ') skills):"

    local found_any=false
    for skill_dir in "$skills_dir"/*/; do
        [ -d "$skill_dir" ] || continue
        found_any=true
        local skill
        skill=$(basename "$skill_dir")
        local version=""
        if [ -f "$skill_dir/CHANGELOG.md" ]; then
            version=$(grep -o 'v[0-9]\+\.[0-9]\+\.[0-9]\+' "$skill_dir/CHANGELOG.md" 2>/dev/null | head -1)
        fi
        echo "  - $skill ${version:-v?}"
    done
}

# =====================================================
# SPECS
# =====================================================

get_next_spec_number() {
    local specs_dir="$DEVORQ_ROOT/docs/specs"
    local max_num=0
    
    shopt -s globstar
    for spec_file in "$specs_dir"/**/*.md; do
        [ -f "$spec_file" ] || continue
        [ "$(basename "$spec_file")" = "_index.md" ] && continue
        
        local spec_id
        spec_id=$(grep -m1 "^id:" "$spec_file" 2>/dev/null | cut -d: -f2 | xargs || true)
        
        if ! validate_spec_id "$spec_id"; then
            continue
        fi
        
        local num=""
        if [[ "$spec_id" =~ ^SPEC-([0-9]{4})- ]]; then
            num="${BASH_REMATCH[1]}"
        fi
        
        if [ -n "$num" ] && [ "$num" -gt "$max_num" ]; then
            max_num="$num"
        fi
    done
    
    printf "%04d" $((10#$max_num + 1))
}

cmd_spec_move() {
    local id="$1"
    local new_status="$2"
    
    if [[ -z "$id" || -z "$new_status" ]]; then
        echo "Uso: devorq spec move <id> <novo_status>"
        return 1
    fi
    
    local valid_statuses=(backlog brainstorming draft approved planning in_progress validated implemented blocked archived)
    local is_valid=0
    for s in "${valid_statuses[@]}"; do
        [[ "$s" == "$new_status" ]] && is_valid=1 && break
    done
    
    if [[ "$is_valid" -eq 0 ]]; then
        echo "Status inválido: $new_status"
        echo "Válidos: ${valid_statuses[*]}"
        return 1
    fi
    
    local spec_file
    spec_file=$(find "$DEVORQ_ROOT/docs/specs" -name "*.md" -type f -exec grep -l "^id: ${id}$" {} \; 2>/dev/null | head -1)
    
    if [[ -z "$spec_file" ]]; then
        echo "Spec não encontrada: $id"
        return 1
    fi
    
    local filename
    filename=$(basename "$spec_file")
    local target_dir="$DEVORQ_ROOT/docs/specs/$new_status"
    local target_file="$target_dir/$filename"
    
    mkdir -p "$target_dir"
    git -C "$DEVORQ_ROOT" mv "$spec_file" "$target_file"
    
    local today
    today=$(date "+%Y-%m-%d")
    sed_inplace "s/^updated_at:.*/updated_at: $today/" "$target_file"
    sed_inplace "s/^status:.*/status: $new_status/" "$target_file"
    
    echo "Moved: $filename -> $new_status/"
}

cmd_spec_new() {
    local title="${*:3}"
    
    if [[ -z "$title" ]]; then
        echo "Uso: devorq spec new \"título da spec\""
        return 1
    fi
    
    local next_num
    next_num=$(get_next_spec_number)
    local date
    date=$(date "+%d-%m-%Y")
    local slug
    slug=$(echo "$title" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9 ]//g' | tr ' ' '-' | tr -s '-')
    slug=${slug%%-}
    slug=${slug##-}
    
    local filename="SPEC-${next_num}-${date}-${slug}.md"
    local target_dir="$DEVORQ_ROOT/docs/specs/draft"
    local target_file="$target_dir/$filename"
    
    mkdir -p "$target_dir"
    
    local today
    today=$(date "+%Y-%m-%d")
    cat > "$target_file" << EOF
---
id: SPEC-${next_num}-${date}-${slug}
title: ${title}
domain: arquitetura
status: draft
priority: medium
author: Nando Dev
owner: ""
source: ""
created_at: ${today}
updated_at: ${today}
related_files: []
related_tasks: []
---

# ${title}

## Contexto



## Decisões



## Critérios de Aceite

- [ ] 

EOF
    
    echo "Spec criada: $target_file"
    
    if [ -n "$EDITOR" ]; then
        $EDITOR "$target_file"
    fi
}

cmd_spec_find() {
    local query="$*"
    
    if [[ -z "$query" ]]; then
        echo "Uso: devorq spec find \"busca\""
        return 1
    fi
    
    local specs_dir="$DEVORQ_ROOT/docs/specs"
    local found=0
    local count=0
    
    echo "Resultados para: $query"
    echo ""
    
    shopt -s globstar
    for f in "$specs_dir"/**/SPEC-*.md; do
        [ -f "$f" ] || continue
        [ "$(basename "$f")" == "_index.md" ] && continue
        
        local basename
        basename=$(basename "$f")
        
        if echo "$basename" | grep -qi "$query"; then
            found=1
        elif grep -qi "$query" "$f" 2>/dev/null; then
            found=1
        fi
        
        if [[ "$found" -eq 1 ]]; then
            count=$((count + 1))
            local id
            id=$(grep -m1 "^id:" "$f" 2>/dev/null | cut -d: -f2 | xargs)
            local title
            title=$(grep -m1 "^title:" "$f" 2>/dev/null | cut -d: -f2 | xargs)
            local status
            status=$(grep -m1 "^status:" "$f" 2>/dev/null | cut -d: -f2 | xargs)
            local relative_path="${f#$DEVORQ_ROOT/}"
            
            echo "📄 $id"
            echo "   Título: $title"
            echo "   Status: $status"
            echo "   Path: $relative_path"
            echo ""
            
            found=0
        fi
    done
    
    if [[ "$count" -eq 0 ]]; then
        echo "Nenhuma spec encontrada para: $query"
    else
        echo "Total: $count spec(s) encontrada(s)"
    fi
}

cmd_spec_validate() {
    local fix=0
    if [[ "$1" == "--fix" ]]; then
        fix=1
    fi
    
    local specs_dir="$DEVORQ_ROOT/docs/specs"
    local issues=0
    
    echo "[DEVORQ] Validando padronização de specs..."
    echo ""
    
    local new_pattern='^SPEC-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{4}-'
    local old_pattern='^SPEC-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{3}$'
    
    shopt -s globstar
    for f in "$specs_dir"/**/SPEC-*.md; do
        [ -f "$f" ] || continue
        [ "$(basename "$f")" == "_index.md" ] && continue
        
        local basename
        basename=$(basename "$f")
        local relative_path="${f#$DEVORQ_ROOT/}"
        
        if [[ "$basename" =~ $old_pattern ]]; then
            issues=$((issues + 1))
            echo "⚠ $basename: Nomenclatura não padronizada"
            echo "  → Era: SPEC-YYYY-MM-DD-NNN"
            echo "  → Deve ser: SPEC-NNNN-DD-MM-AAAA-slug"
            echo "  → Path: $relative_path"
            echo ""
        fi
        
        if ! grep -q "^id:" "$f" 2>/dev/null; then
            issues=$((issues + 1))
            echo "⚠ $basename: Front matter sem 'id'"
            echo "  → Path: $relative_path"
            echo ""
        fi
        
        local status
        status=$(grep -m1 "^status:" "$f" 2>/dev/null | cut -d: -f2 | xargs)
        if [[ -n "$status" ]]; then
            local expected_dir="$specs_dir/$status"
            local actual_dir
            actual_dir=$(dirname "$f")
            if [[ "$expected_dir" != "$actual_dir" ]]; then
                issues=$((issues + 1))
                echo "⚠ $basename: Status '$status' não corresponde à pasta"
                echo "  → Pasta atual: $actual_dir"
                echo "  → Deveria estar em: $expected_dir"
                echo ""
            fi
        fi
    done
    
    echo ""
    if [[ "$issues" -gt 0 ]]; then
        echo "[DEVORQ] Encontrados $issues problema(s)"
        if [[ "$fix" -eq 0 ]]; then
            echo ""
            echo "Para corrigir automaticamente, execute:"
            echo "  ./bin/devorq spec validate --fix"
        else
            echo "[DEVORQ] Correção automática não implementada ainda"
        fi
        return 1
    else
        echo "[DEVORQ] Todas as specs padronizadas ✓"
        return 0
    fi
}

cmd_spec() {
    local subcmd="${2:-index}"
    case "$subcmd" in
        index)
            local spec_index="$DEVORQ_ROOT/bin/spec-index"
            if [ -f "$spec_index" ]; then
                log "📋 Gerando índice de specs..."
                bash "$spec_index"
            else
                log_error "bin/spec-index não encontrado"
                return 1
            fi
            ;;
        list)
            local index_file="$DEVORQ_ROOT/docs/specs/_index.md"
            if [ -f "$index_file" ]; then
                cat "$index_file"
            else
                log_error "Índice não encontrado. Execute: devorq spec index"
                return 1
            fi
            ;;
        status)
            spec_status
            ;;
        update)
            spec_update
            ;;
        move)
            cmd_spec_move "$3" "$4"
            ;;
        new)
            cmd_spec_new "$@"
            ;;
        find)
            cmd_spec_find "$3"
            ;;
        validate)
            shift 2
            cmd_spec_validate "$@"
            ;;
        migrate)
            spec_migrate
            ;;
        *)
            log_error "Subcomando desconhecido: $subcmd"
            echo "Uso: devorq spec [index|list|status|update|move|new|find|validate|migrate]"
            return 1
            ;;
    esac
}

spec_status() {
    log "📊 Analisando status das specs..."
    echo ""

    local specs_dir="$DEVORQ_ROOT/docs/specs"
    local count_approved=0
    local count_implemented=0
    local count_invalid_id=0

    shopt -s globstar
    for spec_file in "$specs_dir"/**/*.md; do
        [ -f "$spec_file" ] || continue
        [ "$(basename "$spec_file")" = "_index.md" ] && continue
        
        local spec_id spec_title spec_status domain related_files related_tasks files_exist
        spec_id=$(grep -m1 "^id:" "$spec_file" 2>/dev/null | cut -d: -f2 | xargs)
        spec_title=$(grep -m1 "^title:" "$spec_file" 2>/dev/null | cut -d: -f2- | xargs)
        spec_status=$(grep -m1 "^status:" "$spec_file" 2>/dev/null | cut -d: -f2 | xargs)
        domain=$(grep -m1 "^domain:" "$spec_file" 2>/dev/null | cut -d: -f2 | xargs)
        
        local id_warning=""
        if ! validate_spec_id "$spec_id"; then
            id_warning=" ⚠️ ID fora do padrão (use: ./bin/devorq spec migrate)"
            count_invalid_id=$((count_invalid_id + 1))
        fi
        
        related_files=$(awk '/^related_files:/,/^---/' "$spec_file" 2>/dev/null | grep -c "^  - " || true)
        related_files=${related_files:-0}
        
        related_tasks=$(grep -c "^  - TASK-" "$spec_file" 2>/dev/null || true)
        related_tasks=${related_tasks:-0}
        
        # Verificar existência dos arquivos
        files_exist=0
        if [ "$related_files" -gt 0 ]; then
            while IFS= read -r f; do
                [ -z "$f" ] && continue
                if [ -e "$f" ] || [ -d "$f" ]; then
                    files_exist=$((files_exist + 1))
                fi
            done < <(awk '/^related_files:/,/^---/' "$spec_file" 2>/dev/null | grep "^  - " | sed 's/^  - //')
        fi
        
        echo "## $spec_id: $spec_title"
        echo "  Status: $spec_status | Domínio: $domain${id_warning}"
        echo "  Related files: $related_files | Encontrados: $files_exist"
        echo "  Related tasks: $related_tasks"
        
        # Critério: related_files > 0 E > 50% existem
        local percent=0
        if [ "$related_files" -gt 0 ]; then
            percent=$((files_exist * 100 / related_files))
        fi
        
        if [ "$spec_status" = "approved" ] && [ "$related_files" -gt 0 ] && [ "$percent" -ge 50 ]; then
            echo "  → Implementada ($percent% existe) ✓"
        elif [ "$spec_status" = "approved" ] && [ "$related_files" -gt 0 ]; then
            echo "  → Parcialmente implementada ($percent% existe)"
        elif [ "$spec_status" = "approved" ]; then
            echo "  → Aguarda implementação"
        fi
        
        echo ""
        
        [ "$spec_status" = "approved" ] && count_approved=$((count_approved + 1))
        [ "$spec_status" = "implemented" ] && count_implemented=$((count_implemented + 1))
    done
    
    echo "---"
    echo "Resumo: $count_approved approved, $count_implemented implemented"
    
    if [ "$count_invalid_id" -gt 0 ]; then
        log_warn "$count_invalid_id specs com ID fora do padrão (execute: ./bin/devorq spec migrate)"
    fi
}

spec_update() {
    log "🔄 Atualizando status das specs..."
    echo ""

    local specs_dir="$DEVORQ_ROOT/docs/specs"
    local updated=0

    shopt -s globstar
    for spec_file in "$specs_dir"/**/*.md; do
        [ -f "$spec_file" ] || continue
        [ "$(basename "$spec_file")" = "_index.md" ] && continue
        
        local spec_id spec_status related_files files_exist percent
        spec_id=$(grep -m1 "^id:" "$spec_file" 2>/dev/null | cut -d: -f2 | xargs)
        spec_status=$(grep -m1 "^status:" "$spec_file" 2>/dev/null | cut -d: -f2 | xargs)
        
        related_files=$(awk '/^related_files:/,/^---/' "$spec_file" 2>/dev/null | grep -c "^  - " || echo "0")
        [ -z "$related_files" ] && related_files=0
        
        files_exist=0
        if [ "$related_files" -gt 0 ]; then
            while IFS= read -r f; do
                [ -z "$f" ] && continue
                if [ -e "$f" ] || [ -d "$f" ]; then
                    files_exist=$((files_exist + 1))
                fi
            done < <(awk '/^related_files:/,/^---/' "$spec_file" 2>/dev/null | grep "^  - " | sed 's/^  - //')
        fi

        percent=0
        [ "$related_files" -gt 0 ] && percent=$((files_exist * 100 / related_files))
        
        if [ "$spec_status" = "approved" ] && [ "$related_files" -gt 0 ] && [ "$percent" -ge 50 ]; then
            log "Atualizando $spec_id: approved → implemented ($files_exist/$related_files = $percent%)"
            sed_inplace "s/^status: approved$/status: implemented/" "$spec_file"
            sed_inplace "s/^updated_at: [0-9-]*$/updated_at: $(date +%Y-%m-%d)/" "$spec_file"
            updated=$((updated + 1))
        fi
    done
    
    echo ""
    log "Specs atualizadas: $updated"
    log "Regenerando índice..."
    bash "$DEVORQ_ROOT/bin/spec-index"
    log_success "Concluído!"
}

spec_migrate() {
    log "🔄 Migrando specs para novo padrão..."
    echo ""
    
    local specs_dir="$DEVORQ_ROOT/docs/specs"
    local migrated=0
    local skipped=0
    
    local next_num
    next_num=$(get_next_spec_number)
    
    echo "Próximo número sequencial: $next_num"
    echo ""
    
    shopt -s globstar
    for spec_file in "$specs_dir"/**/*.md; do
        [ -f "$spec_file" ] || continue
        [ "$(basename "$spec_file")" = "_index.md" ] && continue
        
        local spec_id spec_title spec_status created_at old_id
        spec_id=$(grep -m1 "^id:" "$spec_file" 2>/dev/null | cut -d: -f2 | xargs || true)
        spec_title=$(grep -m1 "^title:" "$spec_file" 2>/dev/null | cut -d: -f2- | xargs || true)
        spec_status=$(grep -m1 "^status:" "$spec_file" 2>/dev/null | cut -d: -f2 | xargs || true)
        created_at=$(grep -m1 "^created_at:" "$spec_file" 2>/dev/null | cut -d: -f2 | xargs || true)
        
        if validate_spec_id "$spec_id"; then
            log_info "Pulando $spec_id (já no padrão)"
            skipped=$((skipped + 1))
            continue
        fi
        
        local day month year
        if [[ "$created_at" =~ ^([0-9]{4})-([0-9]{2})-([0-9]{2})$ ]]; then
            year="${BASH_REMATCH[1]}"
            month="${BASH_REMATCH[2]}"
            day="${BASH_REMATCH[3]}"
        else
            day=$(date +%d)
            month=$(date +%m)
            year=$(date +%Y)
        fi
        
        local slug
        slug=$(echo "$spec_title" | iconv -f UTF-8 -t ASCII//TRANSLIT 2>/dev/null | sed 's/[^a-zA-Z0-9 ]//g' | tr ' ' '-' | tr '[:upper:]' '[:lower:]' | sed 's/--*/-/g' | sed 's/^-//' | sed 's/-$//' | cut -c1-60)
        [ -z "$slug" ] && slug="untitled"
        
        local new_id="SPEC-${next_num}-${day}-${month}-${year}"
        
        echo "Migrando: $spec_id → $new_id"
        
        sed_inplace "s/^id:.*/id: $new_id/" "$spec_file"
        
        local dir
        dir=$(dirname "$spec_file")
        local new_filename="${dir}/${new_id}-${slug}.md"
        
        if [ -f "$new_filename" ]; then
            log_warn "Arquivo já existe: $new_filename"
            continue
        fi
        
        mv "$spec_file" "$new_filename"
        
        migrated=$((migrated + 1))
        next_num=$(printf "%04d" $((10#$next_num + 1)))
    done
    
    echo ""
    echo "---"
    echo "Migradas: $migrated | Puladas: $skipped"
    
    if [ "$migrated" -gt 0 ]; then
        log "Regenerando índice..."
        bash "$DEVORQ_ROOT/bin/spec-index"
        log_success "Concluído!"
    fi
}

# =====================================================
# LIÇÕES
# =====================================================

cmd_lessons() {
    local subcmd="${2:-list}"
    case "$subcmd" in
        list)
            lessons_list "$DEVORQ_DIR"
            ;;
        validate)
            lessons_validate "$DEVORQ_DIR"
            ;;
        apply)
            lessons_apply "$DEVORQ_DIR" "${3:-}"
            ;;
        *)
            log_error "Subcomando desconhecido: $subcmd"
            echo "Uso: devorq lessons <list|validate|apply> [nome]"
            exit 1
            ;;
    esac
}

# =====================================================
# HANDOFF
# =====================================================

cmd_handoff() {
    local subcmd="${2:-status}"
    case "$subcmd" in
        generate)
            log "Gerando handoff file..."
            local handoff_file
            handoff_file=$(generate_handoff "$DEVORQ_DIR" "$DEVORQ_ROOT")
            log_success "Handoff gerado: $handoff_file"
            echo ""
            echo "[Gate 4] Revisar o handoff antes de passar para o próximo LLM:"
            echo ""
            cat "$handoff_file"
            echo ""
            echo "Arquivo: $handoff_file"
            ;;
        status)
            handoff_status "$DEVORQ_DIR"
            ;;
        list)
            handoff_list "$DEVORQ_DIR"
            ;;
        update)
            handoff_update_status "$DEVORQ_DIR" "${3:-em_andamento}"
            ;;
        *)
            log_error "Subcomando desconhecido: $subcmd"
            echo "Uso: devorq handoff <generate|status|list|update>"
            exit 1
            ;;
    esac
}

# =====================================================
# SKILL (versioning e rollback)
# =====================================================

cmd_skill() {
    local subcmd="${2:-list}"
    case "$subcmd" in
        rollback)
            local skill_name="${3:-}"
            local target_version="${4:-}"
            if [ -z "$skill_name" ] || [ -z "$target_version" ]; then
                echo "Uso: devorq skill rollback <nome_skill> <versao>"
                echo "Exemplo: devorq skill rollback scope-guard v1.0.0"
                exit 1
            fi
            skill_rollback "$DEVORQ_DIR/skills" "$skill_name" "$target_version"
            ;;
        version)
            local skill_name="${3:-}"
            local bump_type="${4:-minor}"
            if [ -z "$skill_name" ]; then
                echo "Uso: devorq skill version <nome_skill> <patch|minor|major>"
                exit 1
            fi
            version_skill "$DEVORQ_DIR/skills" "$skill_name" "$bump_type"
            ;;
        versions)
            local skill_name="${3:-}"
            if [ -z "$skill_name" ]; then
                echo "Uso: devorq skill versions <nome_skill>"
                exit 1
            fi
            local versions_dir="$DEVORQ_DIR/skills/$skill_name/VERSIONS"
            if [ -d "$versions_dir" ]; then
                echo "Versões disponíveis para $skill_name:"
                ls -1 "$versions_dir" | sed 's/.md$//' | sed 's/^/  /'
            else
                echo "Nenhuma versão encontrada para $skill_name"
            fi
            ;;
        *)
            log_error "Subcomando desconhecido: $subcmd"
            echo "Uso: devorq skill <rollback|version|versions>"
            exit 1
            ;;
    esac
}

cmd_context_mode() {
    local ctx_status
    ctx_status=$(detect_context_mode "$DEVORQ_ROOT")

    echo ""
    echo "=== Context-Mode (Modo Monstro) ==="
    echo ""

    case "$ctx_status" in
        not_installed)
            echo "🐉 Status: ❌ NÃO INSTALADO"
            echo ""
            echo "O Context-Mode não está instalado neste ambiente."
            echo ""
            echo "Para instalar:"
            echo "  npm install -g context-mode"
            echo ""
            echo "Ou use o instalador do seu ambiente (nvm, yarn, etc.)"
            ;;
        no_sessions)
            echo "🐉 Status: ⚠️ SEM SESSÕES"
            echo ""
            echo "Context-Mode instalado, mas sem sessões ativas."
            echo ""
            echo "Para inicializar uma sessão:"
            echo "  devorq context-mode init"
            ;;
        no_session)
            echo "🐉 Status: 🔶 SEM SESSÃO PARA ESTE PROJETO"
            echo ""
            echo "Este projeto ainda não tem uma sessão indexada."
            echo ""
            echo "Para criar sessão e indexar:"
            echo "  devorq context-mode init"
            echo "  devorq context-mode index"
            ;;
        active:*)
            local ctx_hash
            local ctx_size
            ctx_hash=$(echo "$ctx_status" | cut -d: -f2)
            ctx_size=$(echo "$ctx_status" | cut -d: -f3)
            echo "🐉 Status: ✅ ATIVO"
            echo "   Session DB: ${ctx_hash}.db (${ctx_size}KB)"
            echo ""
            echo "   Economia estimada: ~45% tokens"
            echo "   Tempo salvo: +35min/sessão"
            ;;
    esac
    echo ""
}

get_context_mode_stats() {
    local ctx_status
    ctx_status=$(detect_context_mode "$DEVORQ_ROOT")

    if [[ "$ctx_status" != active:* ]]; then
        echo "Context-Mode não está ativo."
        return 1
    fi

    local ctx_hash
    local ctx_size
    ctx_hash=$(echo "$ctx_status" | cut -d: -f2)
    ctx_size=$(echo "$ctx_status" | cut -d: -f3)

    echo "Session: ${ctx_hash}.db"
    echo "DB Size: ${ctx_size}KB"

    if command -v ctx > /dev/null 2>&1; then
        echo ""
        echo "Comandos disponíveis:"
        echo "  devorq context-mode status   # Verificar status"
        echo "  devorq context-mode doctor  # Diagnóstico"
        if ctx --help 2>/dev/null | grep -q "search"; then
            echo "  devorq context-mode search # Buscar no índice"
        fi
    fi
}

cmd_context_mode_cli() {
    local subcmd="${2:-status}"

    case "$subcmd" in
        status) cmd_context_mode ;;
        stats)
            echo "=== Context-Mode Stats ==="
            get_context_mode_stats
            ;;
        doctor)
            if command -v ctx > /dev/null 2>&1; then
                ctx doctor
            else
                log_error "ctx não encontrado no PATH"
            fi
            ;;
        init)
            if command -v ctx > /dev/null 2>&1; then
                ctx init
            else
                log_error "ctx não encontrado no PATH. Instale o context-mode primeiro."
            fi
            ;;
        index)
            if command -v ctx > /dev/null 2>&1; then
                ctx index "$DEVORQ_ROOT" "devorq"
            else
                log_error "ctx não encontrado no PATH"
            fi
            ;;
        search)
            shift 2
            if command -v ctx > /dev/null 2>&1; then
                ctx search "$*"
            else
                log_error "ctx não encontrado no PATH"
            fi
            ;;
        *)
            echo "Uso: devorq context-mode {status|stats|doctor|init|index|search}"
            exit 1
            ;;
    esac
}

cmd_upgrade() {
    local target="${2:-}"

    if [ -z "$target" ]; then
        log_error "Informe o caminho do projeto a atualizar."
        echo "Uso: devorq upgrade <caminho_do_projeto>"
        echo "Exemplo: devorq upgrade ~/projects/meu-projeto"
        exit 1
    fi

    target="$(realpath "$target")"

    if [ ! -d "$target" ]; then
        log_error "Diretório não encontrado: $target"
        exit 1
    fi

    if [ ! -d "$HOME/.devorq" ]; then
        log_error "DEVORQ global não instalado. Execute: curl -fsSL https://raw.githubusercontent.com/nandinhos/devorq/main/install-devorq.sh | bash"
        exit 1
    fi

    local version
    version=$(cat "$HOME/.devorq/VERSION")

    log "Atualizando DEVORQ em: $target"

    mkdir -p "$target/.devorq/state"

    if [ -f "$target/.devorq/version" ]; then
        local old_version
        old_version=$(cat "$target/.devorq/version")
        if [ "$old_version" != "$version" ]; then
            echo "  📦 $old_version → $version"
        fi
    fi

    echo "$version" > "$target/.devorq/version"

    log_success "DEVORQ $version atualizado em: $target"
    echo ""
    echo "Estrutura: minimal (usa ~/.devorq/ global)"
}

cmd_install() {
    local target_dir="${1:-.}"

    if [ ! -d "$HOME/.devorq" ]; then
        echo "ERRO: DEVORQ não instalado globalmente."
        echo "Execute: curl -fsSL https://raw.githubusercontent.com/nandinhos/devorq/main/install-devorq.sh | bash"
        return 1
    fi

    cd "$target_dir" || return 1

    echo "Instalando DEVORQ..."

    local version
    version=$(cat "$HOME/.devorq/VERSION")

    if [ -f ".devorq/version" ]; then
        local installed_version
        installed_version=$(cat ".devorq/version")
        if [ "$installed_version" = "$version" ]; then
            echo "DEVORQ já está na versão $version (mais recente)"
            return 0
        fi
        echo "Atualizando version file de $installed_version para $version..."
    fi

    mkdir -p .devorq/state .devorq/logs

    echo "$version" > .devorq/version

    if [ ! -d ".git" ]; then
        git init
        echo ".devorq/" >> .gitignore
        echo ".devorq/logs/" >> .gitignore
        echo "Projeto inicializado com git"
    fi

echo ""
    echo "DEVORQ $version instalado em $(pwd)"
    echo "Estrutura: minimal (usa ~/.devorq/ global)"
    echo ""

    local shell_rc=""
    if [ -f "$HOME/.bashrc" ]; then
        shell_rc="$HOME/.bashrc"
    elif [ -f "$HOME/.zshrc" ]; then
        shell_rc="$HOME/.zshrc"
    fi

    if [ -n "$shell_rc" ]; then
        if ! grep -q 'HOME/.devorq/bin' "$shell_rc" 2>/dev/null; then
            echo 'export PATH="$HOME/.devorq/bin:$PATH"' >> "$shell_rc"
            echo "PATH atualizado em $shell_rc"
        fi
    else
        echo "Adicione manualmente ao seu shell RC:"
        echo "  export PATH=\"\$HOME/.devorq/bin:\$PATH\""
    fi
}

cmd_update() {
    if [ ! -d "$HOME/.devorq" ]; then
        echo "ERRO: DEVORQ não instalado localmente"
        return 1
    fi

    echo "Atualizando DEVORQ..."
    git -C "$HOME/.devorq" pull origin main

    local version
    version=$(cat "$HOME/.devorq/VERSION")
    echo "DEVORQ atualizado para v$version"

    local projects_dir="${PROJECTS_DIR:-$HOME/projects}"
    local updated_count=0
    local already_updated_count=0
    local legacy_count=0
    local found_count=0

    if [ -d "$projects_dir" ]; then
        echo ""
        echo "Projetos DEVORQ encontrados:"

        for proj in "$projects_dir"/*; do
            [ -d "$proj" ] || continue

            local proj_name
            proj_name=$(basename "$proj")

            if [ "$proj_name" = "devorq" ]; then
                continue
            fi
            if [ -d "$proj/.devorq" ]; then
                found_count=$((found_count + 1))
                local proj_name
                proj_name=$(basename "$proj")

                if [ -f "$proj/.devorq/version" ]; then
                    local proj_version
                    proj_version=$(cat "$proj/.devorq/version" 2>/dev/null)
                    if [ "$proj_version" != "$version" ]; then
                        echo "  📦 $proj_name: v$proj_version → v$version"
                        mkdir -p "$proj/.devorq/state"
                        echo "$version" > "$proj/.devorq/version"
                        updated_count=$((updated_count + 1))
                    else
                        echo "  ✓ $proj_name: v$version (ok)"
                        already_updated_count=$((already_updated_count + 1))
                    fi
                else
                    echo "  🔶 $proj_name: .devorq sem version (instalacao antiga)"
                    mkdir -p "$proj/.devorq/state"
                    echo "$version" > "$proj/.devorq/version"
                    legacy_count=$((legacy_count + 1))
                fi
            fi
        done

        if [ "$found_count" -eq 0 ]; then
            echo "  Nenhum projeto com DEVORQ instalado encontrado"
            echo ""
            echo "Para instalar DEVORQ num projeto:"
            echo "  cd ~/projects/seu-projeto"
            echo "  devorq install"
        else
            echo ""
            echo "Resumo: $updated_count atualizado(s), $already_updated_count ja atualizado(s), $legacy_count instalacao antiga(s)"
        fi
    fi

    echo ""
    echo "Concluido."
}

cmd_activate() {
    if [ ! -d ".devorq" ]; then
        echo "ERRO: DEVORQ não instalado neste projeto. Rode: devorq install"
        return 1
    fi

    DEVORQ_ROOT="$(pwd)/.devorq"
    export DEVORQ_ROOT

    if [ ! -d "$HOME/.devorq" ]; then
        echo "AVISO: DEVORQ global não encontrado. Instale com:"
        echo "  curl -fsSL https://raw.githubusercontent.com/nandinhos/devorq/main/install-devorq.sh | bash"
    fi

    echo "DEVORQ ativado — v$(cat ".devorq/version" 2>/dev/null || echo "?") em $(pwd)"
    echo "Usando: ${HOME}/.devorq/ global"
}

cmd_deactivate() {
    if [ -n "$DEVORQ_ROOT" ]; then
        echo "DEVORQ desativado (era: $DEVORQ_ROOT)"
    fi
    unset DEVORQ_ROOT
    PATH=$(echo "$PATH" | tr ':' '\n' | grep -v "$(pwd)/bin" | tr '\n' ':' | sed 's/:$//')
    export PATH
}

cmd_help() {
    local _version
    _version=$(cat "$DEVORQ_ROOT/VERSION" 2>/dev/null | tr -d '[:space:]' || echo "?")
    cat << EOF
DEVORQ v${_version} — Orquestrador de Desenvolvimento Multi-LLM

Uso: devorq <comando> [opcoes]

Comandos principais:
  init                          Inicializar projeto (detectar stack, tipo, regras)
  flow <intent>                 Executar fluxo completo para uma task
  agent                         Mostrar modo de agente ativo
  context                       Mostrar contexto detectado
  checkpoint                    Criar checkpoint de continuidade
  info                          Mostrar info resumida
  skills                        Listar skills disponíveis com versões

Context-Mode (Modo Monstro):
  context-mode status           Verificar status do Modo Monstro
  context-mode stats            Estatísticas do DB de sessão
  context-mode doctor           Diagnóstico do context-mode
  context-mode init             Inicializar sessão de indexação
  context-mode index [path]     Re-indexar projeto no contexto
  context-mode search "<query>" Buscar no índice de contexto

Specs:
  spec index                    Gerar índice de todas as specs
  spec list                     Listar specs (do índice)
  spec status                   Analisar status das specs
  spec new "<titulo>"           Criar nova spec em draft/
  spec find "<busca>"           Buscar specs por termo
  spec move <id> <status>        Mover spec para outro status
  spec validate [--fix]         Validar padronização das specs
  spec migrate                  Migrar specs para novo padrão

Handoff multi-LLM:
  handoff generate              Gerar spec padronizada para próximo LLM (Gate 4)
  handoff status                Mostrar status do handoff atual
  handoff list                  Listar histórico de handoffs
  handoff update <status>      Atualizar status (em_andamento|aguardando_merge|concluido)

Pipeline de aprendizado:
  lessons list                  Listar lições pendentes, validadas e aplicadas
  lessons validate              Exibir lições para validação via Context7 (Gate 6)
  lessons apply <nome>         Aplicar lição numa skill (Gate 7)

Versionamento de skills:
  skill rollback <skill> <v>   Reverter skill para versão anterior
  skill version <skill> <bump>  Criar snapshot de nova versão (patch|minor|major)
  skill versions <skill>       Listar versões disponíveis de uma skill

Manutenção:
  upgrade <path>                Atualizar DEVORQ em outro projeto
  install [path]                Instalar DEVORQ no projeto atual
  update|self-upgrade           Atualizar DEVORQ local
  activate                     Ativar DEVORQ no projeto atual
  deactivate                   Desativar DEVORQ no projeto atual

Fluxo obrigatório:
  1. devorq init
  2. /scope-guard            [Gate 1: aprovar contrato]
  3. /pre-flight             [Gate 2: aprovar antes de implementar]
  4. devorq handoff generate [Gate 4: aprovar antes de trocar LLM]
  5. TDD RED->GREEN->REFACTOR
  6. /quality-gate           [Gate 3: aprovar antes de commitar]
  7. /session-audit
  8. /learned-lesson         [Gate 5: salvar lições?]
  9. devorq lessons validate [Gate 6: validação Context7]
 10. devorq lessons apply    [Gate 7: aplicar nas skills]

Ver também:
  devorq --version            Mostrar versão
EOF
}

# =====================================================
# MAIN
# =====================================================

case "${1:-help}" in
    init)        cmd_init ;;
    flow)        cmd_flow "$@" ;;
    agent)       cmd_agent ;;
    context)     cmd_context ;;
    checkpoint)  cmd_checkpoint ;;
    info)        cmd_info ;;
    skills)      cmd_skills ;;
    lessons)     cmd_lessons "$@" ;;
    handoff)     cmd_handoff "$@" ;;
    skill)       cmd_skill "$@" ;;
    spec)        cmd_spec "$@" ;;
    context-mode) cmd_context_mode_cli "$@" ;;
    upgrade)     cmd_upgrade "$@" ;;
    install)     cmd_install "$2" ;;
    update|self-upgrade) cmd_update ;;
    activate)    cmd_activate ;;
    deactivate)  cmd_deactivate ;;
    help|--help|-h) cmd_help ;;
    --version|-v) cat "$DEVORQ_ROOT/VERSION" 2>/dev/null | tr -d '[:space:]'; echo ;;
    *)           log_error "Comando desconhecido: $1"; cmd_help; exit 1 ;;
esac