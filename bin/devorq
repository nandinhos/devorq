#!/bin/bash
# DEVORQ - CLI Principal
# Orquestrador de desenvolvimento orientado a skills

set -eEo pipefail

DEVORQ_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DEVORQ_DIR="$DEVORQ_ROOT/.devorq"

# Cores
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

log() { echo -e "${CYAN}[DEVORQ]${NC} $1"; }
log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}✓${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

# Carregar módulos
source "$DEVORQ_ROOT/lib/detect.sh"

# =====================================================
# COMANDOS
# =====================================================

cmd_init() {
    log "🚀 Inicializando DEVORQ..."
    
    # Criar estrutura
    mkdir -p "$DEVORQ_DIR/state"/{checkpoints,session-audits,spec-exports,lessons-learned,brainstorms,contracts,specs}
    mkdir -p "$DEVORQ_DIR/rules"
    mkdir -p "$DEVORQ_DIR/docs"
    
    # Detectar contexto
    local stack=$(detect_stack "$DEVORQ_ROOT")
    local project_type=$(detect_project_type "$DEVORQ_ROOT")
    local llm=$(detect_llm)
    local runtime=$(detect_runtime)
    local db=$(detect_database)
    
    log_info "Stack: $stack"
    log_info "Tipo: $project_type"
    log_info "LLM: $llm"
    log_info "Runtime: $runtime"
    log_info "Banco: $db"
    
    # Detectar PRD
    local prd=$(check_prd_exists "$DEVORQ_ROOT")
    if [ -n "$prd" ]; then
        log_info "PRD: $prd"
    else
        log_info "PRD: não encontrado"
    fi
    
    # Detectar legado
    if is_legacy "$DEVORQ_ROOT"; then
        log_warn "Sistema LEGADO detectado"
    fi
    
    # Salvar state
    cat > "$DEVORQ_DIR/state/session.json" << EOF
{
  "stack": "$stack",
  "project_type": "$project_type",
  "llm": "$llm",
  "runtime": "$runtime",
  "database": "$db",
  "prd": "$prd",
  "initialized_at": "$(date -Iseconds)",
  "version": "1.0.0-dev"
}
EOF
    
    # Criar regras do projeto
    establish_project_rules "$project_type" "$stack"
    
    log_success "DEVORQ inicializado!"
}

establish_project_rules() {
    local project_type="$1"
    local stack="$2"
    
    case "$project_type" in
        "greenfield")
            cat > "$DEVORQ_DIR/rules/project.md" << EOF
# Regras do Projeto - Greenfield

## Contexto
- Tipo: Sistema novo
- Stack: $stack
- Regra: Arquitetura primeiro, código depois

## Regras de Ouro
1. TDD Obrigatório
2. PRD como fonte de verdade
3. Code Review antes de merge

## Padrões
- Estrutura: MVC padrão
- Testes: Feature tests
- Linter: Pint
EOF
            ;;
        "brownfield")
            cat > "$DEVORQ_DIR/rules/project.md" << EOF
# Regras do Projeto - Brownfield

## Contexto
- Tipo: Projeto em andamento
- Stack: $stack
- Regra: "First, do no harm"

## Regras de Ouro
1. Consistência com padrões existentes
2. TDD para novas funcionalidades
3. Minimalismo
4. Documentar com /learned-lesson
EOF
            ;;
    esac
}

cmd_flow() {
    shift
    local intent="$1"
    
    if [ -z "$intent" ]; then
        log_error "Intent necessário. Uso: devorq flow 'minha task'"
        exit 1
    fi
    
    # Executar fluxo completo
    bash "$DEVORQ_ROOT/lib/orchestration/flow.sh" flow "$intent"
}

cmd_agent() {
    log "=== DEVORQ AGENT MODE ==="
    echo ""
    
    # Mostrar contexto atual
    local stack=$(detect_stack "$DEVORQ_ROOT")
    local project_type=$(detect_project_type "$DEVORQ_ROOT")
    local llm=$(detect_llm)
    local runtime=$(detect_runtime)
    
    cat << EOF
Stack:     $stack
Tipo:      $project_type
LLM:       $llm
Runtime:   $runtime
Versão:    $(cat "$DEVORQ_ROOT/VERSION")

## Fluxo Completo:
1. /env-context     → Detectar contexto automaticamente
2. /scope-guard     → Contrato de escopo (OBRIGATÓRIO)
3. /pre-flight      → Validar tipos/enums
4. /schema-validate → Validar banco
5. tdd              → RED → GREEN → REFACTOR
6. /quality-gate    → Checklist (OBRIGATÓRIO)
7. /session-audit   → Métricas (OBRIGATÓRIO)
8. checkpoint       → Para continuidade

## Para iniciar uma task:
  devorq flow "implementar feature X"
EOF
}

cmd_context() {
    export_context
}

cmd_checkpoint() {
    local timestamp=$(date +%Y%m%d_%H%M%S)
    local checkpoint_dir="$DEVORQ_DIR/state/checkpoints"
    
    mkdir -p "$checkpoint_dir"
    
    local git_status=""
    if git rev-parse --git-dir > /dev/null 2>&1; then
        git_status=$(git status --short 2>/dev/null | head -10)
    fi
    
    cat > "$checkpoint_dir/cp_${timestamp}.md" << EOF
# Checkpoint - $timestamp

## Git Status
\`\`\`
$git_status
\`\`\`

## Contexto
- Stack: $(detect_stack "$DEVORQ_ROOT")
- Tipo: $(detect_project_type "$DEVORQ_ROOT")
- LLM: $(detect_llm)
EOF
    
    log_success "Checkpoint: cp_${timestamp}.md"
}

cmd_info() {
    cat << EOF
=== DEVORQ CONTEXT ===
Stack:     $(detect_stack "$DEVORQ_ROOT")
Tipo:      $(detect_project_type "$DEVORQ_ROOT")
LLM:       $(detect_llm)
Runtime:   $(detect_runtime)
Banco:     $(detect_database)
Versão:    $(cat "$DEVORQ_ROOT/VERSION")
EOF
}

cmd_skills() {
    echo "Skills DEVORQ:"
    ls -1 "$DEVORQ_DIR/skills/" 2>/dev/null | sed 's|/||g' | while read skill; do
        echo "  - $skill"
    done
}

cmd_help() {
    cat << EOF
DEVORQ - Desenvolvimento Orquestrador

Uso: devorq <comando> [opções]

Comandos:
  init              Inicializar projeto (detectar stack, tipo, regras)
  flow <intent>     Executar fluxo completo para uma task
  agent             Ativar modo agente
  context           Mostrar contexto atual
  checkpoint        Criar checkpoint
  info              Mostrar info resumida
  skills            Listar skills
  help              Esta ajuda

Fluxo:
  devorq init                           → Configurar projeto
  devorq flow "implementar autenticação" → Executar task completa

Exemplo:
  devorq init
  devorq flow "criar sistema de login OAuth2"
EOF
}

# =====================================================
# MAIN
# =====================================================

case "${1:-help}" in
    init)       cmd_init ;;
    flow)      cmd_flow "$@" ;;
    agent)     cmd_agent ;;
    context)   cmd_context ;;
    checkpoint) cmd_checkpoint ;;
    info)      cmd_info ;;
    skills)    cmd_skills ;;
    help|--help|-h) cmd_help ;;
    *)         log_error "Comando desconhecido: $1"; cmd_help; exit 1 ;;
esac