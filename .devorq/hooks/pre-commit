#!/usr/bin/env bash
# DEVORQ pre-commit hook — syntax check lightweight
# Instalar via: ./bin/devorq hooks install

set -euo pipefail

DEVORQ_ROOT="$(git rev-parse --show-toplevel)"

echo "[DEVORQ hook] verificando sintaxe Bash..."

bash -n "${DEVORQ_ROOT}/bin/devorq" || {
    echo "[DEVORQ hook] ERRO: bin/devorq tem erro de sintaxe. Commit bloqueado."
    exit 1
}

shopt -s globstar
for f in "${DEVORQ_ROOT}"/lib/*.sh "${DEVORQ_ROOT}"/lib/**/*.sh; do
    [[ -f "$f" ]] || continue
    bash -n "$f" 2>/dev/null || {
        echo "[DEVORQ hook] ERRO: $f tem erro de sintaxe. Commit bloqueado."
        exit 1
    }
done

if command -v shellcheck &>/dev/null; then
    echo "[DEVORQ hook] Rodando shellcheck..."
    shellcheck --severity=error "${DEVORQ_ROOT}/bin/devorq" || exit 1
    shellcheck --severity=error "${DEVORQ_ROOT}"/lib/*.sh || exit 1
fi

# Detecção de stack para lint condicional
if [ -f "${DEVORQ_ROOT}/lib/detection.sh" ]; then
    # shellcheck source=lib/detection.sh
    source "${DEVORQ_ROOT}/lib/detection.sh"
    detected_stack=$(detect_stack "${DEVORQ_ROOT}" 2>/dev/null || echo "generic")
    echo "[DEVORQ hook] Stack: ${detected_stack}"
    case "$detected_stack" in
        laravel|livewire|filament|php)
            echo "[DEVORQ hook] Lint: PHP disponivel via composer"
            ;;
        *)
            echo "[DEVORQ hook] Lint nao aplicavel para stack ${detected_stack}"
            ;;
    esac
fi

echo "[DEVORQ hook] PASS — Pre-commit validado."